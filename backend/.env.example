# ── Option A: Hugging Face Inference Providers (default) ─────────────
HUGGINGFACEHUB_API_TOKEN=hf_replace_with_your_token
# The default chat model is set in config/default.yaml. Override here if needed.
# HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
# HF_PROVIDER=auto   # or: hf-inference, together, novita, fireworks-ai, ...

# ── Option B: OpenAI-compatible endpoint (Groq, OpenRouter, Ollama, OpenAI) ─
# If LLM_BASE_URL is set, it takes precedence over HF. Useful if HF returns 410.
# Groq (free, fast):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your_groq_key
# LLM_MODEL=llama-3.1-8b-instant
# OpenRouter (many free models):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-...
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Local Ollama:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.1

EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=BAAI/bge-reranker-large
CHROMA_DIR=./data/chroma
UPLOADS_DIR=./data/uploads
BM25_DIR=./data/bm25
REGISTRY_DB=./data/registry.sqlite
SAMPLE_PDF_PATH=./data/pdfs/TechNova_HR_Policy_Handbook.pdf
MAX_UPLOAD_MB=25

# ── Tier 3.2 — Optional Postgres ──────────────────────────────────────────
# When DATABASE_URL is set, store.py uses Postgres instead of SQLite.
# REGISTRY_DB above is ignored. Bring up the Postgres service first:
#   docker compose -f homework-basic/docker-compose.yml --profile postgres up -d
# Then uncomment + re-seed:
#   python -m entrypoint.seed --wipe
# DATABASE_URL=postgresql://prism:prism_pass@localhost:5433/prism
